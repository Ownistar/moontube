rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Hardcoded Master Identity
    function isMasterAdmin() {
      return isSignedIn() && 
             request.auth.token.get('email', '').lower() == "itzluci52@gmail.com";
    }

    // Registered Admin Identity
    function isRegisteredAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAdmin() {
      return isMasterAdmin() || isRegisteredAdmin();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 256 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName']) &&
             data.uid == request.auth.uid &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (data.get('earningsBalance', 0) is number) &&
             (data.get('totalViews', 0) is int) &&
             (data.get('subscriberCount', 0) is int);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin()); 
      
      allow create: if isVerified() && isOwner(userId) && isValidUser(incoming());
      
      allow update: if (isVerified() && (isOwner(userId) || isAdmin())) && isValidId(userId) && (
        // Action: Update Profile
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'paypalEmail']) && isValidUser(incoming())) ||
        // Action: Join MPP
        (incoming().diff(existing()).affectedKeys().hasOnly(['mppJoinedAt']) && incoming().mppJoinedAt is string) ||
        // Action: Payout Request
        (incoming().diff(existing()).affectedKeys().hasOnly(['earningsBalance']) &&
         incoming().earningsBalance == (existing().earningsBalance - existing().earningsBalance))
      );
      
      // Stats tracking for creators by viewers
      allow update: if isVerified() && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['totalViews', 'earningsBalance', '_viewForVideoId']) &&
         existsAfter(/databases/$(database)/documents/videoViews/$(incoming().get('_viewForVideoId', 'none') + "_" + request.auth.uid))) ||
        // Action: Subscription tracking
        (incoming().diff(existing()).affectedKeys().hasOnly(['subscriberCount']))
      );
    }

    // --- Video Validation ---
    function isValidVideo(data) {
      return data.keys().hasAll(['ownerId', 'title', 'youtubeUrl', 'youtubeId', 'category']) &&
             data.ownerId == request.auth.uid &&
             data.category is string &&
             data.title is string && data.title.size() <= 200 &&
             data.youtubeUrl is string && data.youtubeUrl.size() <= 512 &&
             data.youtubeId is string && data.youtubeId.size() <= 50;
    }

    match /videos/{videoId} {
      allow read: if true;
      allow create: if isVerified() && isValidVideo(incoming()) && isValidId(videoId);
      allow update: if isVerified() && (isOwner(existing().ownerId) || isAdmin()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'thumbnail', 'category'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['views', 'likes', 'dislikes']))
      );
      // Secure tracking update for viewers
      allow update: if isVerified() && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['views']) &&
         existsAfter(/databases/$(database)/documents/videoViews/$(videoId + "_" + request.auth.uid))) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['dislikes']))
      );
      allow delete: if isVerified() && (isOwner(existing().ownerId) || isAdmin());
    }

    match /subscriptions/{subId} {
      allow read: if isSignedIn() && (resource == null || resource.data.subscriberId == request.auth.uid || resource.data.creatorId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.subscriberId == request.auth.uid || resource.data.creatorId == request.auth.uid || isAdmin());
      allow create, delete: if isVerified() && isValidId(subId);
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(commentId);
      allow delete: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /watchLater/{watchLaterId} {
      allow get: if isVerified() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && incoming().userId == request.auth.uid && isValidId(watchLaterId);
      allow delete: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /userLikes/{likeId} {
      allow get: if isVerified() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && incoming().userId == request.auth.uid && isValidId(likeId);
      allow delete: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /userDislikes/{dislikeId} {
      allow get: if isVerified() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && incoming().userId == request.auth.uid && isValidId(dislikeId);
      allow delete: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /userHistory/{historyId} {
      allow get: if isVerified() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && incoming().userId == request.auth.uid && isValidId(historyId);
      allow update: if isVerified() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && 
                   incoming().diff(existing()).affectedKeys().hasOnly(['timestamp']) &&
                   incoming().videoId == existing().videoId;
      allow delete: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /videoViews/{viewId} {
      allow get: if isVerified() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && incoming().userId == request.auth.uid && !exists(/databases/$(database)/documents/videoViews/$(viewId)) && isValidId(viewId);
    }

    // --- Transaction Validation ---
    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'status', 'paypalEmail', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.status in ['pending', 'completed', 'failed'] &&
             data.createdAt != null;
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidTransaction(incoming()) && isValidId(transactionId);
      allow update: if isAdmin() && 
                   existing().status == 'pending' &&
                   incoming().status in ['completed', 'failed'] &&
                   (
                     incoming().diff(existing()).affectedKeys().hasOnly(['status']) ||
                     incoming().diff(existing()).affectedKeys().hasOnly(['status', 'createdAt'])
                   );
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin() || isRegisteredAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isVerified() && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow update, delete: if isVerified() && resource.data.userId == request.auth.uid;
    }
  }
}
