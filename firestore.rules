rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Hardcoded Master Identity - case-insensitive
    function isMasterAdmin() {
      return isSignedIn() && 
             request.auth.token.get('email', '').lower() == "itzluci52@gmail.com";
    }

    // Registered Admin Identity
    function isRegisteredAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAdmin() {
      return isMasterAdmin() || isRegisteredAdmin();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 256;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (data.get('earningsBalance', 0) is number) &&
             (data.get('totalViews', 0) is int) &&
             (data.get('subscriberCount', 0) is int);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (request.auth.uid == userId || isAdmin()); 
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == request.auth.uid;
      
      allow update: if (isOwner(userId) || isAdmin()) && isValidId(userId) && (
        // Action: Update Profile
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'paypalEmail']) && isValidUser(incoming())) ||
        // Action: Join MPP
        (incoming().diff(existing()).affectedKeys().hasOnly(['mppJoinedAt']) && incoming().mppJoinedAt is string) ||
        // Action: Payout Request
        (incoming().diff(existing()).affectedKeys().hasOnly(['earningsBalance']) &&
         incoming().earningsBalance == (existing().earningsBalance - existing().earningsBalance))
      );
      
      allow update: if isSignedIn() && (
        // Action: Stats tracking for creators by viewers (Economical mode: no view docs)
        (incoming().diff(existing()).affectedKeys().hasOnly(['totalViews', 'earningsBalance'])) ||
        // Action: Subscription tracking
        (incoming().diff(existing()).affectedKeys().hasOnly(['subscriberCount']))
      );
    }

    // --- Video Validation ---
    function isValidVideo(data) {
      return data.keys().hasAll(['ownerId', 'title', 'youtubeUrl', 'youtubeId', 'category']) &&
             data.ownerId is string &&
             data.category is string &&
             data.title is string && data.title.size() <= 200 &&
             data.youtubeUrl is string && data.youtubeUrl.size() <= 512 &&
             data.youtubeId is string && data.youtubeId.size() <= 50;
    }

    match /videos/{videoId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidVideo(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if (isOwner(existing().ownerId) || isAdmin()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'thumbnail', 'category'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['views', 'likes', 'dislikes']))
      );
      // Economical tracking update for viewers
      allow update: if isSignedIn() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['views', 'likes', 'dislikes'])
      );
      allow delete: if isOwner(existing().ownerId) || isAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /watchLater/{watchLaterId} {
      allow read, create, delete: if isSignedIn();
    }

    match /userLikes/{likeId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn() && (request.auth.uid == request.resource.data.userId || request.auth.uid == resource.data.userId);
    }

    match /userDislikes/{dislikeId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn() && (request.auth.uid == request.resource.data.userId || request.auth.uid == resource.data.userId);
    }

    match /userHistory/{historyId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Transaction Validation ---
    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'status', 'paypalEmail', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.status in ['pending', 'completed', 'failed'];
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'createdAt'])
      );
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      // Allow syncing admin list if they are a hardcoded master admin or already an admin
      allow write: if isMasterAdmin() || isRegisteredAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
